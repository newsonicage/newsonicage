# ══════════════════════════════════════════════
# NEWSONIC AGE — Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════

# ── Google OAuth Credentials ──────────────────
# Get these from: console.cloud.google.com
#   → Create Project → APIs & Services → Credentials → OAuth 2.0 Client IDs
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Google Refresh Token ──────────────────────
# One-time setup: run the server locally, visit /auth/google, complete OAuth,
# then copy the refresh_token printed to the console into this variable.
# Once set, the server connects to Calendar on startup — no OAuth flow needed.
GOOGLE_REFRESH_TOKEN=your_refresh_token_here

# ── OAuth Callback URL ────────────────────────
# Must match exactly what you set in Google Cloud Console
# For local dev: http://localhost:3000/auth/google/callback
# For production: https://yourdomain.com/auth/google/callback
REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Calendar Settings ─────────────────────────
# CALENDAR_ID: Use 'primary' for your main calendar,
# or a specific calendar ID (find it in Google Calendar Settings)
CALENDAR_ID=primary

# TIMEZONE: IANA timezone string for your business location
# Examples: America/New_York | America/Los_Angeles | America/Chicago
#           Europe/London | Europe/Paris | Asia/Tokyo
TIMEZONE=America/New_York

# ── Email Notifications ───────────────────────
# GMAIL_USER: your Gmail address
# GMAIL_APP_PASSWORD: 16-char App Password (myaccount.google.com → Security → App passwords)
GMAIL_USER=your_gmail_here@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# ── Frontend API Base URL ─────────────────────
# Controls which backend the booking page calls.
#
# Local dev  → leave blank (empty string) so fetch('/availability') hits the
#              same Express server that serves the HTML — no cross-origin needed.
#
# Production → set to your Render backend URL (no trailing slash):
#              API_BASE_URL=https://newsonicage-backend.onrender.com
#
# To switch environments: update this value and restart the server.
# The browser receives it via GET /config.js as window.API_BASE_URL.
API_BASE_URL=

# ── Server ────────────────────────────────────
PORT=3000
